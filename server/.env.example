# ── Thefirst Permission V1 — environment template ──
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามสภาพแวดล้อมจริง
# (Plesk: ไปที่ Node.js application → "Custom environment variables" แล้วใส่ค่าเหล่านี้ก็ได้)

# Node mode — 'production' บนเซิร์ฟเวอร์จริง, 'development' บนเครื่อง dev
NODE_ENV=production

# พอร์ตที่เซิร์ฟเวอร์ Node ฟัง (Plesk จะ proxy จาก 443 → พอร์ตนี้)
PORT=6500

# Bind address. ใน Plesk แนะนำ 127.0.0.1 เพื่อไม่เปิดออก LAN ตรง ๆ
HOST=127.0.0.1

# ตำแหน่งเก็บฐานข้อมูล SQLite (.db, -wal, -shm จะถูกสร้างที่นี่)
# เว้นว่าง = ใช้ ./data ใต้โฟลเดอร์ server
# Plesk: แนะนำให้ตั้งเป็น path นอก document root เพื่อความปลอดภัย
# DATA_DIR=/var/www/vhosts/example.com/permission-data

# Trust proxy — ใส่ 'loopback' หรือ '1' เมื่ออยู่หลัง Plesk/nginx
# ถ้า expose Node ตรง ๆ ห้ามใส่ ไม่งั้น IP ใน audit log จะถูก spoof ผ่าน X-Forwarded-For
TRUST_PROXY=loopback

# Seed default accounts (it.admin/somchai/preecha/sudarat with password=1234)
# Production ปิดเป็น default — เปิดได้แค่ครั้งเดียวเพื่อ bootstrap เท่านั้น
SEED_DEFAULTS=0
